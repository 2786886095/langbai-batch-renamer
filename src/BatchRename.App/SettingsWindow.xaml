<Window x:Class="BatchRename.App.SettingsWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Width="520" Height="400" ResizeMode="NoResize" WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid Margin="26">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel><TextBlock Text="设置" FontSize="22" FontWeight="SemiBold"/><TextBlock Text="管理更新检查与软件信息。" Foreground="{StaticResource MutedBrush}" Margin="0,5,0,18"/></StackPanel>
        <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="10" Padding="18">
            <StackPanel>
                <TextBlock Text="软件更新" FontSize="16" FontWeight="SemiBold"/>
                <CheckBox x:Name="StartupUpdateCheck" Content="打开软件时自动检查更新" Margin="0,14,0,5" AutomationProperties.Name="打开软件时自动检查更新"/>
                <TextBlock Text="发现新版本时会弹出说明，可直接下载安装包。网络失败不会影响软件启动。" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                <Grid Margin="0,18,0,0"><TextBlock x:Name="VersionText" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"/><Button Style="{StaticResource SecondaryButton}" Content="立即检查更新" HorizontalAlignment="Right" Click="CheckNow_Click" AutomationProperties.AutomationId="CheckUpdateButton"/></Grid>
            </StackPanel>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Style="{StaticResource SecondaryButton}" Content="取消" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Style="{StaticResource PrimaryButton}" Content="保存设置" Click="Save_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
