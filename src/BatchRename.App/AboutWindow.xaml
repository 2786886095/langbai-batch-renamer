<Window x:Class="BatchRename.App.AboutWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="关于" Width="520" Height="350" ResizeMode="NoResize" WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid Margin="28">
        <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel HorizontalAlignment="Center" Width="410">
            <Image Source="/Assets/BatchRenameMark.png" Width="58" Height="58" Margin="0,0,0,14"/>
            <TextBlock Text="浪白重命名工具" FontSize="23" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            <TextBlock x:Name="VersionText" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center" Margin="0,5,0,14"/>
            <TextBlock Text="安全、可预览、可回退的 Windows 资源管理器批量重命名工具。" TextAlignment="Center" Foreground="{StaticResource MutedBrush}"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,22,0,0">
                <Button Style="{StaticResource SecondaryButton}" Content="打开 GitHub 仓库" Margin="0,0,10,0" Click="OpenGithub_Click"/>
                <Button Style="{StaticResource SecondaryButton}" Content="查看版本发布" Click="OpenReleases_Click"/>
            </StackPanel>
        </StackPanel>
        <Button Grid.Row="1" Style="{StaticResource PrimaryButton}" Content="关闭" HorizontalAlignment="Right" Click="Close_Click" IsDefault="True"/>
    </Grid>
</Window>
