<Window x:Class="BatchRename.App.FinalPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="最终重命名预览" Width="900" Height="640" MinWidth="720" MinHeight="480"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" UseLayoutRounding="True" SnapsToDevicePixels="True">
    <Grid Background="#F8FAFC">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

        <Border Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1" Padding="24,20">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="最终重命名预览" FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock x:Name="SummaryText" Foreground="{StaticResource MutedBrush}" Margin="0,5,0,0"/>
                </StackPanel>
                <Border Grid.Column="1" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="8" Padding="12,8" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE946;" FontFamily="Segoe Fluent Icons" Foreground="#2563EB" Margin="0,0,7,0"/><TextBlock Text="确认后才会改动磁盘" Foreground="#385A78"/></StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="20" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="10">
            <DataGrid ItemsSource="{Binding}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="None" RowHeaderWidth="0" RowHeight="46" ColumnHeaderHeight="40"
                      Background="White" BorderThickness="0" AlternatingRowBackground="#FAFCFE" EnableRowVirtualization="True">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader"><Setter Property="Background" Value="#F1F5F9"/><Setter Property="Foreground" Value="#475569"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Padding" Value="12,10"/><Setter Property="BorderBrush" Value="#E2E8F0"/><Setter Property="BorderThickness" Value="0,0,0,1"/></Style>
                    <Style TargetType="DataGridRow"><Setter Property="BorderBrush" Value="#E8EDF3"/><Setter Property="BorderThickness" Value="0,0,0,1"/><Setter Property="VerticalContentAlignment" Value="Center"/></Style>
                    <Style TargetType="DataGridCell"><Setter Property="Padding" Value="12,8"/><Setter Property="BorderThickness" Value="0"/><Setter Property="VerticalContentAlignment" Value="Center"/></Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="" Width="46"><DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding TypeGlyph}" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="#2563EB" HorizontalAlignment="Center" VerticalAlignment="Center"/></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="原名称（只读）" Width="*"><DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding OriginalName}" Foreground="#64748B" TextTrimming="CharacterEllipsis" ToolTip="{Binding OriginalName}" VerticalAlignment="Center"/></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="" Width="46"><DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="&#xE72A;" FontFamily="Segoe Fluent Icons" Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center"/></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="新名称（将写入）" Width="1.2*"><DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding NewName}" Foreground="#0F4DA8" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" ToolTip="{Binding NewName}" VerticalAlignment="Center"/></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0" Padding="20,14">
            <Grid>
                <Button x:Name="CopyButton" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left" Content="复制变更清单" Click="Copy_Click" ToolTip="复制“原名称 → 新名称”文本"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource SecondaryButton}" Content="返回修改" Margin="0,0,10,0" Click="Cancel_Click" IsCancel="True"/>
                    <Button Style="{StaticResource PrimaryButton}" Content="确认重命名" Click="Confirm_Click" IsDefault="True" AutomationProperties.Name="确认重命名" AutomationProperties.AutomationId="ConfirmRenameButton"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
