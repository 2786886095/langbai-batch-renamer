<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\BatchRename.Core\BatchRename.Core.csproj" />
    <Resource Include="Assets\BatchRenameMark.png" />
  </ItemGroup>

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <AssemblyName>BatchRename</AssemblyName>
    <RootNamespace>BatchRename.App</RootNamespace>
    <Version>1.0.0</Version>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon Condition="Exists('Assets\BatchRename.ico')">Assets\BatchRename.ico</ApplicationIcon>
  </PropertyGroup>

</Project>
