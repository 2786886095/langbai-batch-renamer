<Window x:Class="BatchRename.App.SavePresetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="保存命名方案" Width="430" Height="235" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" UseLayoutRounding="True">
    <Grid Margin="24">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <TextBlock Text="保存命名方案" FontSize="20" FontWeight="SemiBold"/>
        <TextBlock Grid.Row="1" Text="方案会保存在本机，下次打开软件仍可使用。重名时会覆盖原方案。" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,16"/>
        <StackPanel Grid.Row="2">
            <TextBlock Text="方案名称" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <TextBox x:Name="NameBox" MaxLength="50" AutomationProperties.Name="方案名称"/>
            <TextBlock x:Name="ErrorText" Foreground="#B42318" Margin="0,6,0,0"/>
        </StackPanel>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Style="{StaticResource SecondaryButton}" Content="取消" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Style="{StaticResource PrimaryButton}" Content="保存方案" Click="Save_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
