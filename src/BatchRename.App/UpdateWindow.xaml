<Window x:Class="BatchRename.App.UpdateWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="发现软件更新" Width="620" Height="500" MinWidth="560" MinHeight="430" WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Border Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1" Padding="24,20">
            <Grid><StackPanel><TextBlock Text="发现新版本" FontSize="22" FontWeight="SemiBold"/><TextBlock x:Name="VersionText" Foreground="{StaticResource MutedBrush}" Margin="0,5,0,0"/></StackPanel><Border HorizontalAlignment="Right" Background="#EFF6FF" CornerRadius="9" Padding="12,7"><TextBlock Text="可更新" Foreground="#1D4ED8" FontWeight="SemiBold"/></Border></Grid>
        </Border>
        <Grid Grid.Row="1" Margin="22">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <TextBlock Text="更新说明" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="9" Padding="15"><ScrollViewer VerticalScrollBarVisibility="Auto"><TextBlock x:Name="NotesText" TextWrapping="Wrap" LineHeight="21"/></ScrollViewer></Border>
            <StackPanel Grid.Row="2" x:Name="ProgressPanel" Visibility="Collapsed" Margin="0,14,0,0"><Grid><TextBlock x:Name="ProgressText" Text="正在下载安装包..."/><TextBlock x:Name="ProgressPercent" HorizontalAlignment="Right"/></Grid><ProgressBar x:Name="DownloadProgress" Height="7" Margin="0,7,0,0" Minimum="0" Maximum="100"/></StackPanel>
        </Grid>
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0" Padding="20,14">
            <Grid><Button Style="{StaticResource SecondaryButton}" Content="打开版本页面" HorizontalAlignment="Left" Click="OpenRelease_Click"/><StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><Button x:Name="LaterButton" Style="{StaticResource SecondaryButton}" Content="稍后提醒" Margin="0,0,10,0" Click="Later_Click"/><Button x:Name="InstallButton" Style="{StaticResource PrimaryButton}" Content="下载并安装" Click="Install_Click" AutomationProperties.AutomationId="DownloadUpdateButton"/></StackPanel></Grid>
        </Border>
    </Grid>
</Window>
